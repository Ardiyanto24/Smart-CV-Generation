# ─── Python ───────────────────────────────────────────
# Compiled bytecode
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
*.whl

# Virtual environments
.venv/
venv/
env/
ENV/

# Test & linting caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Environment files (secrets — never commit these)
.env
.env.*
!.env.example

# ─── Node ─────────────────────────────────────────────
# Dependencies
node_modules/

# Next.js build output
.next/
out/

# Vercel deployment config
.vercel/

# Local env files (Next.js convention)
*.local

# ─── OS ───────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── IDE ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Logs ─────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

